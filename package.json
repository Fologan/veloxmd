{
  "name": "veloxmd",
  "version": "0.1.0-alpha.4",
  "description": "In-place markdown editor. Zero dependencies. The text formats itself.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsup && node -e \"require('fs').copyFileSync('src/styles.css','dist/styles.css')\"",
    "build:check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "markdown",
    "editor",
    "wysiwyg",
    "contenteditable",
    "in-place",
    "live-preview",
    "zero-dependency",
    "lightweight"
  ],
  "author": "Fologan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fologan/veloxmd.git"
  },
  "bugs": {
    "url": "https://github.com/Fologan/veloxmd/issues"
  },
  "homepage": "https://fastmd.vercel.app",
  "devDependencies": {
    "happy-dom": "^20.8.9",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  }
}
